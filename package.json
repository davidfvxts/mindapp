{
  "name": "mira",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mira — an AI reflection coach. Evidence-based daily reflection, gamified.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "esbuild scripts/test-game.ts --bundle --platform=node --format=cjs --outfile=node_modules/.mira-test.cjs --log-level=error && node node_modules/.mira-test.cjs",
    "ios:init": "cap init Mira so.mira.app --web-dir=dist",
    "ios:add": "npm run build && cap add ios",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.2",
    "@capacitor/local-notifications": "^6.1.0",
    "@supabase/supabase-js": "^2.45.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5"
  }
}
