# ---------------------------------------------------------------
# Facet environment. Copy to `.env.local` and fill in.
# EVERYTHING HERE IS OPTIONAL. With no .env.local the app runs
# fully local-first: entries in localStorage, rule-based coach.
# ---------------------------------------------------------------

# --- Supabase (enables sign-in + cloud sync) ---
# Get these from: Supabase dashboard > Project Settings > API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- AI coach endpoint ---
# The deployed Supabase Edge Function that proxies Anthropic.
# Leave blank to use the offline rule-based coach.
VITE_COACH_URL=https://YOUR-PROJECT.supabase.co/functions/v1/coach

# ---------------------------------------------------------------
# NOTE: your Claude API key is NOT set here. It never touches
# the browser. Set it as a Supabase Edge Function secret:
#   supabase secrets set claude_secret_api_key=sk-ant-...
# ANTHROPIC_API_KEY remains supported as a fallback for existing environments.
# ---------------------------------------------------------------
